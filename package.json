{
  "name": "vollio-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Vollio - A full-stack note-taking application",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspaces",
    "start": "npm start --workspace=server",
    "lint": "npm run lint --workspaces",
    "test": "npm test --workspaces",
    "server:dev": "npm run dev --workspace=server",
    "backend:build": "npm run build --workspace=backend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend"
  },
  "workspaces": [
    "server",
    "client",
    "packages/shared"
  ],
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
